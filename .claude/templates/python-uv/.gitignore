# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# uv. `uv.lock` itself MUST be committed (it is the reproducibility source
# of truth — see pyproject.toml header). Only ignore the backup uv writes
# during conflict resolution.
uv.lock.bak

# data: raw and processed are local-only by default. results and builds are
# tracked because they ARE the artifact. Override per project if a result is
# too large to commit.
data/raw/*
!data/raw/.gitkeep
!data/raw/*.README.md
data/processed/*
!data/processed/.gitkeep

# Runtime / OS / IDE
.DS_Store
.vscode/
.idea/
*.swp

# Build outputs that should not be checked in (in-tree builds).
# data/builds/<build_id>/ IS tracked — that's the immutable build record.
build/
target/

# Per-machine probe output written by .claude/hooks/session-start.py. The
# template ships a documented stub at this path; the hook rewrites it on
# each session start. Different machines have different Codex/Gemini paths,
# so it does not belong in version control.
.claude/logs/setup-status.json
.claude/logs/cli/
.claude/logs/sessions.log
